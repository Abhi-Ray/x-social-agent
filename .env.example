# ─── Telegram Bot (approval + control) ───
# Create a NEW bot separate from jarvis-assistant via @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric chat IDs allowed to approve/reject
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# Comma-separated numeric user IDs allowed to approve/reject
TELEGRAM_ALLOWED_USER_IDS=123456789
# The chat ID where drafts are sent for approval
TELEGRAM_TARGET_CHAT_ID=123456789

# ─── OpenRouter (SEPARATE key from jarvis-assistant) ───
# Create a new OpenRouter account/key — do not reuse jarvis's key
OPENROUTER_API_KEY=

# ─── Supabase (can be same project as jarvis or a new one) ───
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Playwright / X session ───
# Path to saved browser session state (generated by `npm run login`)
STORAGE_STATE_PATH=./storageState.json
# X/Twitter handle (without @) — used for scraping your own timeline for context
X_HANDLE=your_handle

# ─── Rate limits (tune, don't delete) ───
# Override defaults from config.ts if needed
# DAILY_CAP_ORIGINAL_POST=6
# DAILY_CAP_RETWEET_COMMENT=4
# DAILY_CAP_REPLY=5
# DAILY_CAP_MENTION=3
# MIN_GAP_SECONDS=180
# JITTER_SECONDS=90

# ─── Cron ───
# Polling interval in minutes for the main tick loop
CRON_INTERVAL_MINUTES=45
